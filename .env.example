# ────────────────────────────────────────────────────────────────────────────
# ManiQuant v1.0 — 환경 변수 템플릿
# 이 파일을 복사하여 .env로 저장한 뒤 값을 채우세요.
# .env 파일은 절대 Git에 커밋하지 마세요!
# ────────────────────────────────────────────────────────────────────────────

# ── LLM API 키 (하나 이상 필수) ──────────────────────────────────────────────
# 우선순위: DeepSeek → Qwen → Claude (Anthropic)
DEEPSEEK_API_KEY=your_deepseek_key_here
QWEN_API_KEY=your_qwen_key_here
ANTHROPIC_API_KEY=your_anthropic_key_here

# ── Milvus 연결 (로컬 Docker 기본값) ─────────────────────────────────────────
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_TOKEN=

# Zilliz Cloud 사용 시:
# MILVUS_HOST=<your-cluster-endpoint>
# MILVUS_PORT=443
# MILVUS_TOKEN=<your-api-key>

# ── Milvus 컬렉션 ────────────────────────────────────────────────────────────
MILVUS_COLLECTION=manidata_anti_aging

# ── 데이터 경로 ──────────────────────────────────────────────────────────────
RAW_DATA_DIR=./data/raw
PROCESSED_DATA_DIR=./data/processed

# ── RAG 파라미터 ─────────────────────────────────────────────────────────────
RAG_TOP_K=5
RAG_SCORE_THRESHOLD=0.5

# ── FastAPI 서버 ─────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
RELOAD=true

# CORS 허용 오리진 (쉼표 구분)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8080
